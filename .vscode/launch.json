{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Electron: Main",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/main.js",
            "args": ["--enable-logging"],
            "env": {
                "NODE_ENV": "development"
            },
            "sourceMaps": true,
            "outputCapture": "std"
        },
        {
            "name": "Electron: Renderer",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}/src",
            "timeout": 30000,
            "sourceMaps": true,
            "urlFilter": "file://*"
        },
        {
            "name": "Electron: Dev",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run electron:dev",
            "cwd": "${workspaceFolder}",
            "presentation": {
                "group": "dev",
                "order": 1
            }
        },
        {
            "name": "Electron: Debug",
            "type": "electron",
            "request": "launch",
            "appDir": "${workspaceFolder}",
            "main": "${workspaceFolder}/main.js",
            "sourceMaps": true,
            "env": {
                "NODE_ENV": "development"
            },
            "protocol": "inspector",
            "webPreferences": {
                "contextIsolation": true,
                "nodeIntegration": false,
                "preload": "${workspaceFolder}/preload.js"
            }
        }
    ],
    "compounds": [
        {
            "name": "Electron: All",
            "configurations": ["Electron: Main", "Electron: Renderer"],
            "presentation": {
                "order": 1
            }
        }
    ]
}