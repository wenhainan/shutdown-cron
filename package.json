{
  "name": "shutdown-cron",
  "version": "1.0.0",
  "description": "Electron + Vue 3 定时关机软件",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron . --enable-logging --v=1",
    "electron:build": "vite build && electron-builder",
    "electron:package": "vite build && electron-packager . --platform=win32 --arch=x64 --out=dist --overwrite",
    "electron:installer": "node build-installer.js"
  },
  "dependencies": {
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.4",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.4",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "vue-tsc": "^1.8.11"
  },
  "author": "Your Name",
  "build": {
    "appId": "com.shutdowncron.app",
    "productName": "定时关机软件",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "dist/**/*",
      "public/**/*",
      "preload.js"
    ],
    "win": {
      "icon": "public/logo.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/logo.png",
      "uninstallerIcon": "public/logo.png",
      "installerHeaderIcon": "public/logo.png"
    },
    "compression": "maximum",
    "publish": {
      "provider": "generic",
      "url": "http://localhost:8080/"
    }
  }
}