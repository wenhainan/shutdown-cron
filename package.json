{
  "name": "shutdown-cron",
  "version": "1.0.0",
  "description": "海豚定时关机 ,轻量级高颜值实用定时关机软件 , 开发者邮箱 whndeweilai@163.com",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron . --enable-logging --v=1",
    "electron:build": "vite build && electron-builder",
    "electron:package": "vite build && electron-packager . --platform=win32 --arch=x64 --out=dist --overwrite --ignore=node_modules --extra-resource=dist --icon=public/logo.ico",
    "electron:installer": "node build-installer.js"
  },
  "dependencies": {
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.4",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.4",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "vue-tsc": "^1.8.11"
  },
  "author": "闻海南",
  "build": {
    "appId": "com.shutdowncron.app",
    "productName": "海豚定时关机",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "dist/**/*",
      "public/**/*",
      "preload.js"
    ],
    "win": {
      "icon": "public/logo.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "海豚定时关机"
    },
    "compression": "maximum"
  }
}