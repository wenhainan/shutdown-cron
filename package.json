{
  "name": "shutdown-cron",
  "version": "1.0.0",
  "description": "Electron + Vue 3 定时关机软件",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron . --enable-logging --v=1",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.4",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "vue-tsc": "^1.8.11"
  },
  "build": {
    "appId": "com.shutdowncron.app",
    "productName": "定时关机软件",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "dist/**/*"
    ],
    "win": {
      "icon": "public/icon.ico"
    }
  }
}